{
  "info": {
    "_postman_id": "d7f142c4-3cd0-4229-aa71-7f3390d5e19f",
    "name": "JobPortal API",
    "description": "Postman collection for the Spring Boot JobPortal API.\n\nThis version stores separate role tokens in the environment:\n- `adminToken`\n- `employerToken`\n- `applicantToken`\n\nRole folders automatically copy the correct one into `currentToken` before requests run, so you usually do not need to switch bearer tokens manually.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "item": [
    {
      "name": "Auth",
      "auth": {
        "type": "noauth"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.environment.unset('currentToken');",
              "pm.request.headers.remove('Authorization');"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "Register Applicant",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const ts = Date.now();",
                  "pm.environment.set('registerApplicantEmail', `applicant.${ts}@example.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Applicant registered', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.environment.set('applicantEmail', pm.environment.get('registerApplicantEmail') || '');",
                  "if (data.userId) {",
                  "  pm.environment.set('applicantUserId', data.userId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Applicant User\",\n  \"email\": \"{{registerApplicantEmail}}\",\n  \"password\": \"Password123!\",\n  \"role\": \"APPLICANT\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
