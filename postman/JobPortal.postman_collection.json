              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data.jobId) {",
                  "    pm.environment.set('jobId', data.jobId);",
                  "    pm.environment.set('jobSearchValue', data.jobId);",
                  "  }",
