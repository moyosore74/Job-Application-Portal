        {
          "name": "Login Applicant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Applicant login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.token) {",
                  "  pm.environment.set('applicantToken', data.token);",
                  "  pm.environment.set('currentToken', data.token);",
                  "  pm.environment.set('activeRole', 'APPLICANT');",
                  "}",
                  "if (data.user) {",
                  "  pm.environment.set('applicantUserId', data.user.userId || '');",
                  "  pm.environment.set('applicantEmail', data.user.email || '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
